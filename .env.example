# ── ORION X Environment Configuration (EXAMPLE) ──
# Copy to .env and fill in real values. .env is git-ignored.

# Backend
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orionx?schema=public"
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRATION="15m"
REFRESH_TOKEN_EXPIRATION="7d"
PORT=4000
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL=http://localhost:3000

# AI Core
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
AI_MODEL_DEFAULT=gpt-4o
AI_EMBEDDING_MODEL=text-embedding-3-large
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Storage
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Redis
REDIS_URL=redis://localhost:6379
